# Copy this file to `.env` and fill in real values from your mbe-api dev
# database, then run:
#   flutter test --dart-define-from-file=.env
#
# These are compile-time constants (String.fromEnvironment), consumed by
# test/integration/*_test.dart. Any value left blank causes the tests that
# depend on it to be skipped rather than fail — fill in only what you have
# seeded data for.
#
# Requires mbe-api reachable at `apiBaseUrl` (default http://127.0.0.1:8000).

# --- auth_flow_test.dart ---
# Administrator account (full access rights).
MBE_ADMIN_USERNAME=
MBE_ADMIN_PASSWORD=
# Non-administrator account with standard access.
MBE_TEST_USERNAME=
MBE_TEST_PASSWORD=

# --- catalog_consistency_flow_test.dart (in addition to the above) ---
# Any user id known to exist, for cross-checking user lookups.
MBE_KNOWN_USER_ID=
# Account with read-only privileges (no create/update/delete rights).
MBE_READONLY_USERNAME=
MBE_READONLY_PASSWORD=

# --- product_catalog_flow_test.dart (in addition to MBE_TEST_USERNAME/PASSWORD) ---
# Product code known to exist in the catalog.
MBE_KNOWN_PRODUCT_CODE=
# Substring known to match at least one product name.
MBE_KNOWN_PRODUCT_NAME_PART=
# Account with products.create rights, used for create/update/deactivate flows.
MBE_CREATE_TEST_USERNAME=
MBE_CREATE_TEST_PASSWORD=

# --- product_photo_flow_test.dart (in addition to MBE_TEST_USERNAME/PASSWORD and
# MBE_READONLY_USERNAME/PASSWORD above) ---
# Product id that already has a photo.
MBE_WITH_PHOTO_PRODUCT_ID=
# Product id that has no photo.
MBE_NO_PHOTO_PRODUCT_ID=
# Product id safe to mutate (upload/replace/remove photo) without affecting
# other tests or real data.
MBE_MUTABLE_PRODUCT_ID=

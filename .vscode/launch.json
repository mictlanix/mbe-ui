            "args": ["-d", "chrome", "--web-port=8081", "--dart-define=LEGACY_PHOTOS_BASE_URL=http://mbe.gruporamoshnos.com"]
        },
        {
            "name": "mbe-ui (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": ["-d", "chrome", "--web-port=8081", "--dart-define=LEGACY_PHOTOS_BASE_URL=http://mbe.gruporamoshnos.com"]
        }
    ]

    "version": "0.2.0",
    "configurations": [
        {
            "name": "mbe-ui",
            "request": "launch",
            "type": "dart",
            "args": ["-d", "chrome", "--web-port=8081", "--dart-define=LEGACY_PHOTOS_BASE_URL=http://mbe.gruporamoshnos.com"]
        },
        {
            "name": "mbe-ui (profile mode)",
            "request": "launch",
            "type": "dart",
